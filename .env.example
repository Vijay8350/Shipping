# ──────────────────────────────────────────────────────────────────────────
# Shipping Management — environment variables (CLAUDE.md §12)
# Copy to `.env` and fill in. NEVER commit a real .env. NEVER log these values.
# ──────────────────────────────────────────────────────────────────────────

# Shopify app credentials (from the Partner Dashboard / shopify.app.toml)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Our own domain — the non-embedded App URL (CLAUDE.md §2).
SHOPIFY_APP_URL=https://ship.apanjob.com

# Least-privilege start set (CLAUDE.md §10). Comma-separated, no spaces.
SCOPES=read_orders,write_orders,read_fulfillments,write_fulfillments,read_products,write_merchant_managed_fulfillment_orders

# Postgres on AWS RDS — NEVER SQLite, in any environment (CLAUDE.md §3).
DATABASE_URL=postgresql://user:password@your-instance.rds.amazonaws.com:5432/shipping?schema=public

# Redis on AWS ElastiCache — used by BullMQ (web enqueues, worker consumes).
REDIS_URL=redis://your-instance.cache.amazonaws.com:6379

# 32-byte key for AES-256-GCM encryption of courier credentials & offline tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# Secret used to sign our own session cookie (non-embedded auth, CLAUDE.md §2).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional: web process port (Nginx/ALB proxies to this).
PORT=3000

# ── Notifications (stubbed in Phase 4; not used yet) ───────────────────────
# MSG91_AUTH_KEY=
# SES_REGION=
# SES_FROM=
